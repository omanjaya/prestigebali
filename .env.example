# Salin ke .env lalu isi. JANGAN commit .env yang berisi nilai asli.

# --- Database (Postgres, lihat docker-compose.yml) ---
DATABASE_URL="postgresql://prestige:prestige@localhost:5432/prestige?schema=public"

# --- Auth.js / NextAuth ---
# Buat dengan: npx auth secret   (atau openssl rand -base64 32)
AUTH_SECRET=""

# --- Payment Gateway: Midtrans (ADR-0002 / ADR-0005) ---
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# --- Notifikasi (ADR-0003) ---
# Email dulu; vendor WhatsApp ditunda (ADR-0005). Isi bila sudah dipilih.
EMAIL_FROM=""
SMTP_URL=""
# WHATSAPP_* — TBD

# --- Aturan bisnis (angka konfigurasi, lihat ADR-0001/0004 & CONTEXT.md) ---
HOLD_TIMEOUT_MINUTES="60"
BUFFER_DAYS="1"
REFUND_ADMIN_FEE="0"
